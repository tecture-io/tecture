{
  "name": "@tecture/core",
  "version": "0.0.3",
  "description": "Next generation architecture documentation generated by coding agents — render file-based architecture diagrams (JSON + Markdown) in your browser.",
  "keywords": [
    "c4",
    "architecture",
    "diagram",
    "documentation",
    "visualization",
    "reactflow",
    "agents",
    "llm",
    "coding-agents"
  ],
  "license": "MIT",
  "author": "Shanika Wijerathna <shanikacj@gmail.com>",
  "homepage": "https://github.com/tecture-io/tecture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tecture-io/tecture.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/tecture-io/tecture/issues"
  },
  "type": "module",
  "bin": "./dist/cli.js",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts --port 3001",
    "build": "tsup && node scripts/copy-web-assets.mjs",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@tecture/shared": "workspace:*",
    "@tecture/web": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
