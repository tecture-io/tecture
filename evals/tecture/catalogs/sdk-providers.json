{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Standalone catalog mapping dependency-manifest entries to the external provider each one implies. Used by criterion B3. Entries are independent of anything under .claude/skills/tecture/. Package names may contain glob wildcards (* prefix/suffix) for SDK families.",
  "providers": [
    { "provider": "stripe",           "packages": ["stripe", "@stripe/stripe-js"] },
    { "provider": "braintree",        "packages": ["braintree"] },
    { "provider": "square",           "packages": ["square", "@square/*"] },
    { "provider": "paddle",           "packages": ["@paddle/paddle-js", "paddle-sdk"] },
    { "provider": "sendgrid",         "packages": ["@sendgrid/*"] },
    { "provider": "resend",           "packages": ["resend"] },
    { "provider": "postmark",         "packages": ["postmark"] },
    { "provider": "mailgun",          "packages": ["mailgun", "mailgun.js"] },
    { "provider": "twilio",           "packages": ["twilio"] },
    { "provider": "auth0",            "packages": ["@auth0/*", "auth0"] },
    { "provider": "clerk",            "packages": ["@clerk/*"] },
    { "provider": "firebase",         "packages": ["firebase", "firebase-admin", "firebase-auth"] },
    { "provider": "next-auth",        "packages": ["next-auth", "@auth/*"] },
    { "provider": "supabase",         "packages": ["@supabase/*", "supabase"] },
    { "provider": "anthropic",        "packages": ["@anthropic-ai/sdk", "anthropic"] },
    { "provider": "openai",           "packages": ["openai"] },
    { "provider": "cohere",           "packages": ["cohere-ai"] },
    { "provider": "together",         "packages": ["together"] },
    { "provider": "replicate",        "packages": ["replicate"] },
    { "provider": "huggingface",      "packages": ["@huggingface/*", "huggingface"] },
    { "provider": "langchain",        "packages": ["langchain", "@langchain/*"] },
    { "provider": "posthog",          "packages": ["posthog", "posthog-js", "posthog-node"] },
    { "provider": "mixpanel",         "packages": ["mixpanel", "mixpanel-browser"] },
    { "provider": "segment",          "packages": ["@segment/*", "analytics-node"] },
    { "provider": "amplitude",        "packages": ["@amplitude/*", "amplitude-js"] },
    { "provider": "sentry",           "packages": ["@sentry/*"] },
    { "provider": "datadog",          "packages": ["@datadog/*", "datadog-metrics", "dd-trace"] },
    { "provider": "newrelic",         "packages": ["newrelic"] },
    { "provider": "opentelemetry",    "packages": ["@opentelemetry/*"] },
    { "provider": "aws-s3",           "packages": ["@aws-sdk/client-s3", "aws-sdk", "boto3"] },
    { "provider": "aws-sqs",          "packages": ["@aws-sdk/client-sqs"] },
    { "provider": "aws-dynamodb",     "packages": ["@aws-sdk/client-dynamodb"] },
    { "provider": "aws-lambda",       "packages": ["@aws-sdk/client-lambda"] },
    { "provider": "aws-ses",          "packages": ["@aws-sdk/client-ses"] },
    { "provider": "aws-sns",          "packages": ["@aws-sdk/client-sns"] },
    { "provider": "gcp-storage",      "packages": ["@google-cloud/storage"] },
    { "provider": "gcp-pubsub",       "packages": ["@google-cloud/pubsub"] },
    { "provider": "gcp-firestore",    "packages": ["@google-cloud/firestore"] },
    { "provider": "azure-blob",       "packages": ["@azure/storage-blob"] },
    { "provider": "azure-servicebus", "packages": ["@azure/service-bus"] },
    { "provider": "cloudflare-r2",    "packages": ["@cloudflare/r2"] },
    { "provider": "cloudflare-workers", "packages": ["wrangler", "@cloudflare/workers-types"] },
    { "provider": "elasticsearch",    "packages": ["@elastic/elasticsearch", "elasticsearch"] },
    { "provider": "algolia",          "packages": ["algoliasearch"] },
    { "provider": "meilisearch",      "packages": ["meilisearch"] },
    { "provider": "typesense",        "packages": ["typesense"] },
    { "provider": "redis",            "packages": ["redis", "ioredis"] },
    { "provider": "memcached",        "packages": ["memcached", "memjs"] },
    { "provider": "cloudinary",       "packages": ["cloudinary"] },
    { "provider": "uploadthing",      "packages": ["uploadthing"] },
    { "provider": "imagekit",         "packages": ["imagekit"] },
    { "provider": "postgres",         "packages": ["pg", "postgres", "psycopg2", "psycopg", "asyncpg"] },
    { "provider": "mysql",            "packages": ["mysql", "mysql2", "pymysql"] },
    { "provider": "mongodb",          "packages": ["mongodb", "mongoose", "pymongo", "motor"] },
    { "provider": "sqlite",           "packages": ["better-sqlite3", "sqlite3"] },
    { "provider": "prisma",           "packages": ["prisma", "@prisma/client"] },
    { "provider": "drizzle",          "packages": ["drizzle-orm"] },
    { "provider": "typeorm",          "packages": ["typeorm"] },
    { "provider": "sequelize",        "packages": ["sequelize"] },
    { "provider": "sqlalchemy",       "packages": ["sqlalchemy"] },
    { "provider": "kafka",            "packages": ["kafkajs", "kafka-python", "confluent-kafka"] },
    { "provider": "rabbitmq",         "packages": ["amqplib", "pika"] },
    { "provider": "nats",             "packages": ["nats"] },
    { "provider": "bullmq",           "packages": ["bullmq", "bull"] },
    { "provider": "celery",           "packages": ["celery"] },
    { "provider": "sidekiq",          "packages": ["sidekiq"] },
    { "provider": "inngest",          "packages": ["inngest"] },
    { "provider": "temporal",         "packages": ["@temporalio/*", "temporalio"] },
    { "provider": "slack",            "packages": ["@slack/web-api", "slack-sdk"] },
    { "provider": "discord",          "packages": ["discord.js", "discord-api-types"] },
    { "provider": "github",           "packages": ["@octokit/*", "pygithub"] },
    { "provider": "linear",           "packages": ["@linear/sdk"] },
    { "provider": "notion",           "packages": ["@notionhq/client"] },
    { "provider": "shopify",          "packages": ["@shopify/*"] }
  ]
}
